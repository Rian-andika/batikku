---
import Layout from '../layouts/Layout.astro';
import { MOTIFS } from '../data/motifs.js';

// Hitung jumlah daerah unik otomatis (biar selalu akurat dengan data)
const uniqueRegions = new Set();
MOTIFS.forEach(m => {
  m.region.split('&').forEach(r => {
    let name = r.trim();
    if (name === 'Solo') name = 'Surakarta';
    if (name) uniqueRegions.add(name);
  });
});
const regionCount = uniqueRegions.size;

// Koordinat geografis ASLI tiap daerah motif (lat, lng)
const REGION_COORDS = {
  "Aceh":              { lat: 5.5483,  lng: 95.3238  },
  "Yogyakarta":        { lat: -7.7956, lng: 110.3695 },
  "Surakarta":         { lat: -7.5755, lng: 110.8243 },
  "Solo & Yogyakarta": { lat: -7.6850, lng: 110.5970 },
  "Cirebon":           { lat: -6.7320, lng: 108.5523 },
  "Jakarta":           { lat: -6.2088, lng: 106.8456 },
  "Banten":            { lat: -6.4058, lng: 106.0640 },
  "Bali":              { lat: -8.4095, lng: 115.1889 },
  "Kalimantan":        { lat: -1.6815, lng: 113.3824 },
  "Kalimantan Timur":  { lat: -1.2654, lng: 116.8312 },
};
---

<Layout title="Peta Asal Motif — Batikku">

  <!-- Leaflet CSS dari CDN -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
        integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>

  <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-16 pt-10 sm:pt-16 pb-4">
    <p class="section-label">◆ Peta Asal Motif</p>
    <h1 class="text-4xl sm:text-6xl tracking-tight mb-4">Setiap daerah, dialeknya sendiri.</h1>
    <p class="text-ink-soft max-w-[54ch]">Telusuri Nusantara dari Sabang sampai Merauke. Klik penanda motif untuk membaca asal-usul batik tiap daerah.</p>
  </div>

  <div class="max-w-content mx-auto px-5 sm:px-8 lg:px-16 pb-20">
    <div class="relative isolate rounded-2xl overflow-hidden shadow-2xl border-2 border-sogan/30">
      <!-- Hint bar -->
      <div class="absolute bottom-4 left-1/2 -translate-x-1/2 z-[400] bg-cream/95 backdrop-blur-sm rounded-full px-4 py-2 shadow-lg text-xs text-ink-soft border border-line whitespace-nowrap">
        🗺️ Drag untuk geser · Scroll untuk zoom · Klik pin untuk motif
      </div>
      <!-- Container peta -->
      <div id="map" class="w-full h-[600px] bg-[#e8dfc8]"></div>
    </div>
    <p class="text-sm text-center mt-4 text-ink-soft italic">Peta Nusantara · {MOTIFS.length} motif dari {regionCount} daerah</p>
  </div>

  <script is:inline define:vars={{ motifsData: MOTIFS, regionCoords: REGION_COORDS }}>
    window.__MOTIFS = motifsData;
    window.__COORDS = regionCoords;
  </script>

  <!-- Leaflet JS dari CDN -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
          integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const MOTIFS = window.__MOTIFS;
      const COORDS = window.__COORDS;

      // === Init peta center Indonesia ===
      const map = L.map('map', {
        center: [-2.5, 118],   // center Indonesia
        zoom: 5,
        minZoom: 4,
        maxZoom: 12,
        scrollWheelZoom: true,
        zoomControl: true,
      });

      // === TILE LAYER dengan style SEPIA ===
      // Pakai OpenStreetMap tile + CSS filter sepia
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> · Batikku 2026',
        className: 'sepia-tile',
      }).addTo(map);

      // === MARKER motif batik (bunga merah-emas) ===
      function batikMarkerIcon(motifCount) {
        const size = 32 + motifCount * 4;
        const svg = `
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="-25 -25 50 50" width="${size}" height="${size}">
            <circle r="22" fill="#7B4A2B" fill-opacity="0.25">
              <animate attributeName="r" values="22;28;22" dur="2.5s" repeatCount="indefinite"/>
              <animate attributeName="fill-opacity" values="0.25;0.05;0.25" dur="2.5s" repeatCount="indefinite"/>
            </circle>
            <g>
              ${[0,72,144,216,288].map(a => `<ellipse cx="0" cy="-9" rx="5" ry="10" fill="#A0341E" transform="rotate(${a})"/>`).join('')}
              <circle r="6" fill="#C9A961" stroke="#7B4A2B" stroke-width="1.5"/>
              <circle r="2.5" fill="#7B4A2B"/>
            </g>
          </svg>
        `;
        return L.divIcon({
          html: svg,
          className: 'batik-marker',
          iconSize: [size, size],
          iconAnchor: [size/2, size/2],
        });
      }

      // === Helper foto motif untuk popup ===
      function motifThumb(m) {
        return `<img src="/images/motifs/${m.id}.jpg" alt="${m.name}"
                  style="width:48px;height:48px;object-fit:cover;border-radius:8px;flex-shrink:0;"
                  onerror="this.style.display='none'" />`;
      }

      // === Bangun marker tiap daerah ===
      const regions = [...new Set(MOTIFS.map(m => m.region))];

      regions.forEach(region => {
        const c = COORDS[region.trim()] || COORDS[region];
        if (!c) { console.warn('Koordinat tidak ada:', region); return; }

        const motifs = MOTIFS.filter(m => m.region === region);
        const count = motifs.length;

        // Konten popup
        const motifsList = motifs.map(m => `
          <a href="/motif/${m.id}" class="motif-item">
            ${motifThumb(m)}
            <div class="motif-info">
              <strong>${m.name}</strong>
              <span>${m.themes.join(', ')}</span>
            </div>
            <span class="motif-arrow">→</span>
          </a>
        `).join('');

        const popupHTML = `
          <div class="batikku-popup">
            <div class="popup-header">
              <span class="popup-label">${count} Motif</span>
              <h3>${region}</h3>
            </div>
            <div class="popup-body">
              ${motifsList}
            </div>
          </div>
        `;

        const marker = L.marker([c.lat, c.lng], {
          icon: batikMarkerIcon(count),
          title: region,
        }).addTo(map);

        marker.bindPopup(popupHTML, {
          maxWidth: 340,
          minWidth: 280,
          className: 'batikku-popup-wrapper',
          autoPanPadding: [40, 40],
        });
      });

      // Auto-fit ke semua marker
      const allCoords = regions
        .map(r => COORDS[r.trim()] || COORDS[r])
        .filter(Boolean)
        .map(c => [c.lat, c.lng]);
      if (allCoords.length > 0) {
        const bounds = L.latLngBounds(allCoords);
        map.fitBounds(bounds, { padding: [50, 50] });
      }
    });
  </script>

  <!-- Style sepia + popup custom -->
  <style is:global>
    /* === FIX z-index: Leaflet harus di bawah header (z-50) === */
    /* Leaflet panes default punya z-index 200-700 yg bikin tile nutupin header.
       Karena container .leaflet-container kita udah pakai isolate + relative,
       seharusnya udah aman, tapi kita pastikan dengan cap eksplisit di sini. */
    .leaflet-container { z-index: 0; }
    .leaflet-pane { z-index: auto; }
    .leaflet-top, .leaflet-bottom { z-index: 10; }
    .leaflet-popup { z-index: 20; }

    /* === SEPIA FILTER untuk tile peta === */
    .sepia-tile {
      filter: sepia(0.65) saturate(0.85) brightness(1.05) contrast(0.92) hue-rotate(-8deg);
    }

    /* === ATTRIBUTION === */
    .leaflet-control-attribution {
      background: rgba(245, 238, 225, 0.9) !important;
      color: #5C3619 !important;
      font-size: 10px !important;
      border-radius: 6px 0 0 0;
    }
    .leaflet-control-attribution a {
      color: #7B4A2B !important;
    }

    /* === ZOOM CONTROL === */
    .leaflet-control-zoom a {
      background: #7B4A2B !important;
      color: #F5EEE1 !important;
      border: 1px solid #5C3619 !important;
      font-weight: bold !important;
    }
    .leaflet-control-zoom a:hover {
      background: #5C3619 !important;
    }

    /* === MARKER bunga batik === */
    .batik-marker {
      background: transparent !important;
      border: none !important;
      cursor: pointer;
      transition: transform 0.2s;
    }
    .batik-marker:hover {
      transform: scale(1.15);
      z-index: 1000 !important;
    }

    /* === POPUP CUSTOM (vintage batikku style) === */
    .batikku-popup-wrapper .leaflet-popup-content-wrapper {
      background: #FAF6EE;
      border: 2px solid #C9A961;
      border-radius: 16px !important;
      box-shadow: 0 10px 40px rgba(31, 26, 21, 0.25);
      padding: 0 !important;
    }
    .batikku-popup-wrapper .leaflet-popup-content {
      margin: 0 !important;
      padding: 0 !important;
      width: auto !important;
    }
    .batikku-popup-wrapper .leaflet-popup-tip {
      background: #FAF6EE;
      border: 2px solid #C9A961;
    }
    .batikku-popup-wrapper .leaflet-popup-close-button {
      color: #1F1A15 !important;
      font-size: 24px !important;
      font-weight: bold !important;
      padding: 8px 12px !important;
      width: auto !important;
      height: auto !important;
    }

    .batikku-popup {
      font-family: 'Hanken Grotesk', system-ui, sans-serif;
      color: #1F1A15;
      max-width: 340px;
    }
    .batikku-popup .popup-header {
      padding: 16px 20px 12px;
      border-bottom: 1px solid #DDD2BE;
    }
    .batikku-popup .popup-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #7B4A2B;
    }
    .batikku-popup .popup-header h3 {
      font-family: 'Fraunces', Georgia, serif;
      font-size: 22px;
      font-weight: 500;
      margin: 4px 0 0 0;
      color: #1F1A15;
      line-height: 1.1;
    }
    .batikku-popup .popup-body {
      padding: 12px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      max-height: 280px;
      overflow-y: auto;
    }
    .batikku-popup .motif-item {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 8px 12px;
      background: #F5EEE1;
      border: 1px solid #DDD2BE;
      border-radius: 12px;
      text-decoration: none;
      color: #1F1A15;
      transition: all 0.2s;
    }
    .batikku-popup .motif-item:hover {
      transform: translateX(3px);
      border-color: #7B4A2B;
      background: #FAF6EE;
    }
    .batikku-popup .motif-info {
      flex: 1;
      min-width: 0;
    }
    .batikku-popup .motif-info strong {
      display: block;
      font-family: 'Fraunces', serif;
      font-size: 16px;
      font-weight: 500;
      line-height: 1.2;
    }
    .batikku-popup .motif-info span {
      font-size: 12px;
      color: #4A4138;
    }
    .batikku-popup .motif-arrow {
      color: #7B4A2B;
      font-size: 18px;
      flex-shrink: 0;
    }

    /* Scrollbar tipis di body popup */
    .batikku-popup .popup-body::-webkit-scrollbar {
      width: 6px;
    }
    .batikku-popup .popup-body::-webkit-scrollbar-thumb {
      background: #C9A961;
      border-radius: 3px;
    }
  </style>
</Layout>
